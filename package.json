{
  "name": "@programytecnologia/whatsapp-business-sdk",
  "author": "ProgramyTecnologia",
  "version": "2.0.2",
  "description": "Node.js connector for the WhatsApp Business APIs with TypeScript support, integration tests and more.",
  "license": "MIT",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/ProgramyTecnologia/whatsapp-business-sdk-xior/blob/main/LICENSE"
    }
  ],
  "packageManager": "pnpm@10.28.1",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "biome check .",
    "format": "biome format . --write",
    "prepare": "husky && tsc --build",
    "cm": "cz",
    "checkup": "pnpm lint && pnpm test && pnpm build",
    "release": "pnpm checkup && npm version"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ProgramyTecnologia/whatsapp-business-sdk-xior.git"
  },
  "homepage": "https://github.com/ProgramyTecnologia/whatsapp-business-sdk-xior",
  "bugs": {
    "url": "https://github.com/ProgramyTecnologia/whatsapp-business-sdk-xior/issues",
    "email": "github@programy.com.br"
  },
  "dependencies": {
    "express": "^5.2.1",
    "form-data": "^4.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jest": "^30.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "devmoji": "^2.3.0",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.2",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "keywords": [
    "meta",
    "connector",
    "nodejs",
    "api",
    "sdk",
    "whatsapp",
    "facebook"
  ]
}